---
interface Props {
  eyebrow?: string;
  title: string;
  copy?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, copy, align = 'left' } = Astro.props;
---

<div class:list={['space-y-4', align === 'center' && 'mx-auto text-center']}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <div class:list={[align === 'center' && 'mx-auto max-w-3xl']}>
    <h2 class="section-title">{title}</h2>
    {copy && <p class:list={['section-copy mt-4', align === 'center' && 'mx-auto']}>{copy}</p>}
  </div>
</div>
