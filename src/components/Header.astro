---
import { site } from '../data/site';
const pathname = Astro.url.pathname;
const links = [
  ['/', 'Home'],
  ['/about', 'About'],
  ['/programmes', 'Programmes'],
  ['/admissions', 'Admissions'],
  ['/gallery', 'Gallery'],
  ['/news', 'News'],
  ['/contact', 'Contact']
];
---

<header class="sticky top-0 z-50 border-b border-white/60 bg-white/80 backdrop-blur-xl">
  <div class="container-shell flex items-center justify-between gap-4 py-4">
    <a href="/" class="flex items-center gap-3">
      <img src="/images/logo/uci-logo.webp" alt="UCI logo" class="h-11 w-11 rounded-full border border-slate-200 object-cover" />
      <div>
        <p class="text-sm font-semibold text-slate-900">{site.shortName}</p>
        <p class="text-xs text-slate-500">School of Nursing & Midwifery</p>
      </div>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {links.map(([href, label]) => (
        <a
          href={href}
          class:list={[
            'rounded-full px-4 py-2 text-sm font-medium transition',
            pathname === href ? 'bg-slate-900 text-white' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <a href={site.admissionsPortal} target="_blank" rel="noreferrer" class="btn-primary hidden md:inline-flex">Apply Online</a>
  </div>

  <div class="container-shell flex gap-2 overflow-x-auto pb-4 md:hidden">
    {links.map(([href, label]) => (
      <a
        href={href}
        class:list={[
          'whitespace-nowrap rounded-full px-4 py-2 text-sm font-medium transition',
          pathname === href ? 'bg-slate-900 text-white' : 'border border-slate-200 bg-white text-slate-600'
        ]}
      >
        {label}
      </a>
    ))}
  </div>
</header>
