---
interface Props {
  item: {
    title: string;
    date: string;
    excerpt: string;
    href: string;
  };
}
const { item } = Astro.props;
---

<article class="glass-card rounded-[1.75rem] p-6">
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">{item.date}</p>
  <h3 class="mt-3 text-xl font-semibold text-slate-900">{item.title}</h3>
  <p class="mt-3 text-sm leading-7 text-slate-600">{item.excerpt}</p>
  <a href={item.href} class="mt-5 inline-flex items-center text-sm font-semibold text-slate-900">Explore →</a>
</article>
