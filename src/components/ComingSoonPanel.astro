---
import { site } from '../data/site';

interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="container-shell py-20 md:py-24">
  <div class="glass-card mx-auto max-w-4xl rounded-[2rem] p-8 md:p-10">
    <span class="eyebrow">{eyebrow}</span>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl">{title}</h1>
    <p class="mt-5 max-w-3xl text-base leading-8 text-slate-600">{description}</p>

    <div class="mt-8 grid gap-5 md:grid-cols-2">
      <article class="rounded-2xl border border-slate-200/80 bg-white/90 p-5">
        <h2 class="text-lg font-semibold text-slate-900">Status</h2>
        <p class="mt-2 text-sm leading-7 text-slate-600">
          This feature page is being prepared. For immediate support, use contact channels below.
        </p>
      </article>

      <article class="rounded-2xl border border-slate-200/80 bg-white/90 p-5">
        <h2 class="text-lg font-semibold text-slate-900">Quick Contact</h2>
        <p class="mt-2 text-sm leading-7 text-slate-600">WhatsApp: {site.whatsAppDisplay}</p>
        <p class="text-sm leading-7 text-slate-600">Phone: {site.phonePrimary}</p>
      </article>
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/contact" class="btn-primary">Contact Admissions</a>
      <a href={`https://wa.me/${site.whatsAppNumber}`} target="_blank" rel="noreferrer" class="btn-whatsapp">WhatsApp {site.whatsAppDisplay}</a>
      <a href="/admissions" class="btn-secondary">Back to Admissions</a>
    </div>
  </div>
</section>
