---
import MainLayout from '../layouts/MainLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTA from '../components/CTA.astro';
import { site } from '../data/site';
---

<MainLayout
  title="Contact | UCI Lira"
  description="Reach UCI Lira admissions and administration for programme, application, and general institute enquiries."
>
  <section class="container-shell py-16 md:py-20">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div class="space-y-6">
        <span class="eyebrow">Contact UCI Lira</span>
        <h1 class="text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl">Direct lines for admissions and institutional enquiries</h1>
        <p class="text-base leading-8 text-slate-600">
          Use the contacts below to request support on programme fit, admissions timelines, and application requirements.
        </p>
      </div>

      <div class="glass-card overflow-hidden rounded-[2rem]">
        <img src="/images/campus/campus-3.webp" alt="Institute landmark and campus environment" decoding="async" class="h-full min-h-[320px] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="container-shell mt-8 space-y-8">
    <SectionHeader
      eyebrow="Reach Us"
      title="Official contact channels"
      copy="Call, email, or visit the institute for enquiry follow-up and admissions guidance."
    />

    <div class="grid gap-6 md:grid-cols-2">
      <article class="glass-card rounded-[1.75rem] p-7">
        <h2 class="text-2xl font-semibold text-slate-900">Admissions and Administration</h2>
        <div class="mt-5 space-y-3 text-sm leading-7 text-slate-700">
          <p>{site.location}</p>
          <a href={`tel:${site.phonePrimary.replace(/\s+/g, '')}`} class="block font-medium text-slate-900 hover:text-blue-700">{site.phonePrimary}</a>
          <a href={`tel:${site.phoneSecondary.replace(/\s+/g, '')}`} class="block font-medium text-slate-900 hover:text-blue-700">{site.phoneSecondary}</a>
          <a href={`mailto:${site.email}`} class="block font-medium text-slate-900 hover:text-blue-700">{site.email}</a>
        </div>
      </article>

      <article class="glass-card rounded-[1.75rem] p-7">
        <h2 class="text-2xl font-semibold text-slate-900">Quick Action Links</h2>
        <div class="mt-5 flex flex-col gap-3">
          <a href={site.admissionsPortal} class="btn-primary">Open Online Portal</a>
          <a href={site.downloadsUrl} class="btn-secondary">Open Downloads</a>
          <a href={site.applicationFormsUrl} class="btn-secondary">Open Application Forms</a>
          <a href={site.profileUrl} target="_blank" rel="noreferrer" class="btn-secondary">View Official Profile</a>
        </div>
      </article>
    </div>
  </section>

  <section class="container-shell mt-20">
    <article class="glass-card rounded-[1.75rem] p-7">
      <h2 class="text-2xl font-semibold text-slate-900">WhatsApp Contact Form</h2>
      <p class="mt-3 text-sm leading-7 text-slate-600">
        Fill this quick form and continue the conversation on WhatsApp with our support line <strong>{site.whatsAppDisplay}</strong>.
      </p>

      <form id="whatsapp-form" class="mt-6 grid gap-4 md:grid-cols-2">
        <label class="space-y-2">
          <span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-600">Full Name</span>
          <input name="name" required placeholder="Your full name" class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-blue-400 focus:ring-2 focus:ring-blue-100" />
        </label>

        <label class="space-y-2">
          <span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-600">Phone Number</span>
          <input name="phone" required placeholder="07XXXXXXXX" class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-blue-400 focus:ring-2 focus:ring-blue-100" />
        </label>

        <label class="space-y-2 md:col-span-2">
          <span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-600">Interest</span>
          <select name="interest" class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
            <option value="Admissions enquiry">Admissions enquiry</option>
            <option value="Programme guidance">Programme guidance</option>
            <option value="Application forms support">Application forms support</option>
            <option value="General information">General information</option>
          </select>
        </label>

        <label class="space-y-2 md:col-span-2">
          <span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-600">Message</span>
          <textarea name="message" rows="4" required placeholder="Type your question..." class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-blue-400 focus:ring-2 focus:ring-blue-100"></textarea>
        </label>

        <div class="md:col-span-2 flex flex-wrap gap-3">
          <button type="submit" class="btn-whatsapp">Send to WhatsApp</button>
          <a href={`https://wa.me/${site.whatsAppNumber}`} target="_blank" rel="noreferrer" class="btn-secondary">Open WhatsApp Chat</a>
        </div>
      </form>
    </article>
  </section>

  <CTA
    title="Ready to proceed with your application?"
    copy="Use the online portal and forms pages for next steps, then keep communication active through admissions contacts or WhatsApp."
    primaryHref={site.admissionsPortal}
    primaryLabel="Apply Online"
    secondaryHref="/admissions"
    secondaryLabel="Admissions Steps"
  />
</MainLayout>

<script is:inline>
  const form = document.getElementById('whatsapp-form');

  if (form) {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const name = String(formData.get('name') || '').trim();
      const phone = String(formData.get('phone') || '').trim();
      const interest = String(formData.get('interest') || '').trim();
      const message = String(formData.get('message') || '').trim();

      const text = [
        'Hello UCI Lira Admissions Team,',
        `Name: ${name}`,
        `Phone: ${phone}`,
        `Interest: ${interest}`,
        `Message: ${message}`
      ].join('\\n');

      const encoded = encodeURIComponent(text);
      window.open(`https://wa.me/256761435295?text=${encoded}`, '_blank', 'noopener,noreferrer');
    });
  }
</script>
