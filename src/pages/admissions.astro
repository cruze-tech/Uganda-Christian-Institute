---
import MainLayout from '../layouts/MainLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTA from '../components/CTA.astro';
import { site, admissionSteps, admissionsChecklist, faqs } from '../data/site';
---

<MainLayout
  title="Admissions | UCI Lira Application Guidance"
  description="Follow the admissions flow for UCI Lira, including programme selection, required documents, and official online application access."
>
  <section class="container-shell py-16 md:py-20">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div class="space-y-6">
        <span class="eyebrow">Admissions Guide</span>
        <h1 class="text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl">Clear admissions flow from enquiry to application</h1>
        <p class="text-base leading-8 text-slate-600">
          This section is designed to help applicants prepare confidently, submit correctly, and follow up with the admissions office when support is needed.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href={site.admissionsPortal} target="_blank" rel="noreferrer" class="btn-primary">Open Admissions Portal</a>
          <a href={site.downloadsUrl} target="_blank" rel="noreferrer" class="btn-secondary">Downloads and Forms</a>
        </div>
      </div>

      <div class="glass-card overflow-hidden rounded-[2rem]">
        <img src="/images/midwifery/midwife-training-1.webp" alt="Midwifery students in practical learning context" class="h-full min-h-[320px] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="container-shell mt-8 space-y-8">
    <SectionHeader
      eyebrow="Step-by-step"
      title="How to apply"
      copy="Use this sequence to move from programme choice to official submission without missing key details."
    />

    <div class="grid gap-5 md:grid-cols-2">
      {admissionSteps.map((step, index) => (
        <article class="glass-card rounded-[1.5rem] p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-blue-700">Step {index + 1}</p>
          <h2 class="mt-3 text-xl font-semibold text-slate-900">{step.title}</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">{step.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container-shell mt-20 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
    <article class="glass-card rounded-[1.75rem] p-7">
      <h2 class="text-2xl font-semibold text-slate-900">Admissions Preparation Checklist</h2>
      <p class="mt-3 text-sm leading-7 text-slate-600">Keep these essentials ready before beginning your online application process.</p>
      <ul class="mt-6 space-y-3 text-sm leading-7 text-slate-700">
        {admissionsChecklist.map((item) => (
          <li class="flex gap-3">
            <span class="mt-2 h-2 w-2 rounded-full bg-blue-700"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </article>

    <article class="glass-card rounded-[1.75rem] p-7">
      <h2 class="text-2xl font-semibold text-slate-900">Direct Admissions Contacts</h2>
      <div class="mt-5 space-y-3 text-sm leading-7 text-slate-700">
        <p>{site.location}</p>
        <a href={`tel:${site.phonePrimary.replace(/\s+/g, '')}`} class="block font-medium text-slate-900 hover:text-blue-700">{site.phonePrimary}</a>
        <a href={`tel:${site.phoneSecondary.replace(/\s+/g, '')}`} class="block font-medium text-slate-900 hover:text-blue-700">{site.phoneSecondary}</a>
        <a href={`mailto:${site.email}`} class="block font-medium text-slate-900 hover:text-blue-700">{site.email}</a>
      </div>
    </article>
  </section>

  <section class="container-shell mt-20 space-y-8">
    <SectionHeader
      eyebrow="FAQs"
      title="Common questions from prospective applicants"
      copy="Quick answers to frequent admissions and demo-deployment questions."
    />

    <div class="grid gap-5 md:grid-cols-3">
      {faqs.map((item) => (
        <article class="glass-card rounded-[1.5rem] p-6">
          <h3 class="text-lg font-semibold text-slate-900">{item.q}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">{item.a}</p>
        </article>
      ))}
    </div>
  </section>

  <CTA
    title="Submit your application through official channels"
    copy="Use the admissions portal for final submission and reach the institute directly for clarifications on entry requirements."
    primaryHref={site.admissionsPortal}
    primaryLabel="Apply Online"
    secondaryHref="/contact"
    secondaryLabel="Contact Admissions"
  />
</MainLayout>
